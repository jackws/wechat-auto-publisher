# ====== 微信公众号自动发布系统 - 环境变量配置 ======
# 复制此文件为 .env 并填入你的实际配置

# AI 模型配置（可选，也可通过 Web UI 配置）
AI_PROVIDER_URL=https://token-plan-cn.xiaomimimo.com/v1/chat/completions
AI_API_KEY=
AI_MODEL=mimo-v2.5-pro
AI_MAX_TOKENS=3000

# 微信公众号配置（可选，也可通过 Web UI 配置）
WECHAT_APP_ID=
WECHAT_APP_SECRET=

# 图片源配置（可选，也可通过 Web UI 配置）
# 启用的图片来源：pexels,bing,cogview,tongyi,custom-ai（逗号分隔）
IMAGE_SOURCES=pexels,cogview
PEXELS_API_KEY=
BING_KEY=
COGVIEW_KEY=
TONGYI_KEY=
# AI 生图数量（0-3）
IMAGE_AI_COUNT=2

# 应用配置
PORT=3000
